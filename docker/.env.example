# Desktop root for all bind-mounted agent data (created by init_desktop_volumes.sh)
LMSTUDIO_AGENT_DATA_ROOT=${HOME}/Desktop/lmstudio-agent

# LM Studio API on the host (Docker Desktop: host.docker.internal)
LMSTUDIO_URL=http://host.docker.internal:1234
BRIDGE_PORT=8765

# Phase 2–3 memory toggles
RAG_ENABLED=1
SUMMARIZER_ENABLED=1

# Private GitHub repo for memory backup (create empty repo, then paste SSH or HTTPS URL)
# Example: git@github.com:you/lmstudio-memory.git
MEMORY_BACKUP_GIT_REMOTE=
MEMORY_BACKUP_GIT_BRANCH=main
BACKUP_INTERVAL_SEC=300

# Git identity for backup commits
GIT_USER_NAME=lmstudio-agent
GIT_USER_EMAIL=agent@local
